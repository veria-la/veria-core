{
  "name": "veria-cli",
  "version": "0.1.0",
  "description": "VERIA — Solana ZK Coprocessor CLI. Few dots. Whole truth.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "veria": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "homebrew"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/index.js",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "pack": "npm pack"
  },
  "dependencies": {
    "@veria/sdk": "workspace:*",
    "@solana/web3.js": "^1.95.0",
    "commander": "^12.1.0",
    "kleur": "^4.1.5",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.10.0",
    "vitest": "^2.1.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://veria.fun",
  "repository": {
    "type": "git",
    "url": "https://github.com/veria-labs/veria-core"
  },
  "keywords": [
    "solana",
    "zk",
    "zkvm",
    "sp1",
    "nova",
    "folding",
    "cli"
  ],
  "engines": {
    "node": ">=20.0.0"
  }
}
