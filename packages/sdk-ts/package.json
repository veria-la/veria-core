{
  "name": "@veria/sdk",
  "version": "0.1.0",
  "description": "VERIA TypeScript SDK — Solana-native ZK Coprocessor. Few dots. Whole truth.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./circuits": {
      "import": "./dist/circuits.js",
      "types": "./dist/circuits.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.0",
    "@coral-xyz/anchor": "^0.30.1",
    "@noble/hashes": "^1.5.0",
    "buffer": "^6.0.3"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.10.0",
    "vitest": "^2.1.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://veria.fun",
  "repository": {
    "type": "git",
    "url": "https://github.com/veria-labs/veria-core"
  },
  "keywords": [
    "solana",
    "zk",
    "zkvm",
    "sp1",
    "nova",
    "folding",
    "coprocessor",
    "verifier",
    "anchor"
  ]
}
